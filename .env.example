# Default report: disaggregated futures-only COT historical compressed report.
# Supported values: disaggregated_futures_only, financial_futures_only, legacy_futures_only
COT_REPORT_TYPE=disaggregated_futures_only

# Leave blank to use current year. Set for repeatable historical runs, e.g. 2025.
COT_YEAR=

# HTTP request timeout in seconds.
REQUEST_TIMEOUT_SECONDS=30
